# Logic (\`*.sc.ts\`)

\`\`\`ts
class Counter extends StreamableLogic {
  state = { n: 0 };

  renderVals() {
    return {
      n: this.state.n,
      inc: () => this.setState(s => ({ n: s.n + 1 })),
